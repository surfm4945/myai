    {
      "id": "init_017",
      "question": "what is the internet",
      "answer": "The Internet is a global network of billions of interconnected computers communicating via standardized protocols (TCP/IP). It enables: World Wide Web (websites), email, streaming, social media, cloud computing, and IoT. Originally ARPANET (1969), it became public in 1991 with the WWW. Today it carries ~5 exabytes of data daily and connects ~5.4 billion people.",
      "tags": [
        "technology"
      ],
      "frequency": 0,
      "created_at": "2024-01-01T00:00:00",
      "last_used": null
    },
